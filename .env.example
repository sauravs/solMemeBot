# ── Database (Neon Postgres) ────────────────────────────────────────────────
# Pooled connection string for the app; use a Neon branch URL in CI.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
# Direct (non-pooled) URL for Prisma migrations, if your setup needs it.
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# ── Auth (single-user gate) ─────────────────────────────────────────────────
AUTH_SECRET="generate-with: openssl rand -base64 32"
# The one account allowed to log in (v1 is private/single-user).
APP_USER="you@example.com"
APP_PASSWORD="set-a-strong-password"

# ── Helius (ChainEvents: webhooks + REST) ───────────────────────────────────
HELIUS_API_KEY=""
# Shared secret you set on the Helius webhook; verified on the receiver route.
HELIUS_WEBHOOK_SECRET=""

# ── Safety (SafetyReporter) ─────────────────────────────────────────────────
# Set to "fake" in dev/CI to use the deterministic fake reporter; leave unset in
# production to use the real RugCheck adapter.
SAFETY_PROVIDER=""
# RugCheck public API needs no key (10 req/min). Optional token raises limits to 60/min.
RUGCHECK_JWT=""

# ── Price (PriceSource) ─────────────────────────────────────────────────────
# Set to "fake" in dev/CI for the deterministic price source; unset in prod to
# use the real Jupiter price API (no key required).
PRICE_PROVIDER=""
BIRDEYE_API_KEY=""
# Let the snapshots cron honor a ?now= override (tests only). Never set in prod.
CRON_TIME_OVERRIDE=""

# ── Alerts (Notifier: Telegram) ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# ── App ─────────────────────────────────────────────────────────────────────
# Public base URL (used for webhook registration / links).
APP_BASE_URL="http://localhost:3000"
# Secret guarding the Vercel Cron route.
CRON_SECRET="generate-a-random-string"
