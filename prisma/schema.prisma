// solMemeBot schema. Domain terms come from CONTEXT.md.
// v1 grows aggregate-by-aggregate as slices land; Slice 0 introduces only User.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// The single owner of the system in v1. Modeled explicitly so ownership can be
/// threaded through for a future multi-tenant SaaS (see docs/ROADMAP.md).
model User {
  id             String          @id @default(cuid())
  email          String          @unique
  createdAt      DateTime        @default(now())
  trackedWallets TrackedWallet[]
  journalEntries JournalEntry[]
  alerts         Alert[]
}

/// A notification emitted for a high-signal event (a tracked-wallet buy, or a
/// tripped safety flag). Persisted in-app; also pushed to Telegram. See CONTEXT.md.
model Alert {
  id      String    @id @default(cuid())
  ownerId String
  owner   User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  type    String
  payload Json
  channel String    @default("in_app")
  sentAt  DateTime  @default(now())
  readAt  DateTime?

  @@index([ownerId, sentAt])
}

/// A real trade the owner manually logged. Its realized PnL is stored net of
/// fees when the trade is closed (an exit price is given). See CONTEXT.md.
model JournalEntry {
  id             String    @id @default(cuid())
  ownerId        String
  owner          User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  token          String
  side           String    @default("buy")
  quantity       Float
  entryPriceUsd  Float
  exitPriceUsd   Float?
  feesUsd        Float     @default(0)
  realizedPnlUsd Float?
  openedAt       DateTime  @default(now())
  closedAt       DateTime?

  @@index([ownerId, openedAt])
}

/// A Solana wallet the owner has chosen to follow as candidate "smart money".
/// Hand-seeded by the user (no auto-discovery in v1). See CONTEXT.md.
model TrackedWallet {
  id        String   @id @default(cuid())
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  address   String
  label     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  signals   Signal[]

  @@unique([ownerId, address])
  @@index([ownerId])
}

/// A Solana SPL token (memecoin), keyed by its mint address. See CONTEXT.md.
model Token {
  mint         String        @id
  symbol       String?
  name         String?
  firstSeenAt  DateTime      @default(now())
  signals      Signal[]
  safetyReport SafetyReport?
}

/// Risk assessment for a Token: flags + a derived roll-up verdict. One current
/// report per token (refreshed in place). See CONTEXT.md and ADR-0003.
model SafetyReport {
  id        String   @id @default(cuid())
  tokenMint String   @unique
  token     Token    @relation(fields: [tokenMint], references: [mint], onDelete: Cascade)
  verdict   String
  flags     Json
  fetchedAt DateTime @default(now())
}

/// The unit we evaluate: a Tracked Wallet's buy of a Token. Ingestion is
/// idempotent — the @@unique makes webhook retries safe. See CONTEXT.md.
model Signal {
  id             String          @id @default(cuid())
  walletId       String
  wallet         TrackedWallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  tokenMint      String
  token          Token           @relation(fields: [tokenMint], references: [mint])
  txSig          String
  side           String          @default("buy")
  signalPriceUsd Float?
  observedAt     DateTime
  createdAt      DateTime        @default(now())
  snapshots      PriceSnapshot[]

  @@unique([walletId, txSig, tokenMint])
  @@index([walletId, observedAt])
  @@index([tokenMint])
}

/// A price recorded forward from a Signal at a fixed horizon (1h/24h/7d), used
/// to compute Hypothetical PnL. One snapshot per (signal, horizon). See CONTEXT.md.
model PriceSnapshot {
  id         String   @id @default(cuid())
  signalId   String
  signal     Signal   @relation(fields: [signalId], references: [id], onDelete: Cascade)
  horizon    String
  priceUsd   Float
  capturedAt DateTime @default(now())

  @@unique([signalId, horizon])
  @@index([signalId])
}
